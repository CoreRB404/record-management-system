# Frontend environment variables for Vite
# Copy to .env.local and edit as needed.

# Base URL for the API. When running locally this points at your backend,
# but if you're using an SSH/ngrok/tunnel you can override it here.
# You can either include the "/api" suffix or let the code append it for you.
# e.g. VITE_API_URL=https://1234abcd.ngrok.io   or  \
#       VITE_API_URL=https://1234abcd.ngrok.io/api
# Leave blank to use the dev proxy (requests will be sent to /api).
VITE_API_URL=http://localhost:5000/api
