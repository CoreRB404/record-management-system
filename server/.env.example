# ──────────────────────────────────────────────────────────────────────
# Environment Configuration Template
# Copy this file to .env and fill in your real values
# NEVER commit the actual .env file to version control!
# ──────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=5000

# MongoDB Connection String
# Use a strong password and whitelist IPs in Atlas Network Access
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT Configuration
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<generate-a-strong-random-secret>
JWT_EXPIRE=1d

# CORS - Comma-separated list of allowed frontend origins
# You can put multiple origins separated by commas, e.g.
#   CORS_ORIGIN=http://localhost:5173,https://my-ngrok-url.ngrok.io
# during development you can also use '*' to allow any origin (not recommended in prod).
CORS_ORIGIN=http://localhost:5173
